{
  "uid": "claude-code-usage-summary",
  "title": "Claude Code 利用サマリー",
  "tags": ["claude-code", "daimon"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "トークン消費(選択期間の合計)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(claude_code_token_usage_tokens_total[$__range]))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "コスト(選択期間の合計、USD)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "アクティブ時間(選択期間の合計)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(claude_code_active_time_seconds_total[$__range]))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "セッション数(選択期間内に開始)",
      "description": "increase() ではなく session_id の種類数で数える。理由は .claude/skills/claude-observability/SKILL.md 参照。",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(count by (session_id) (last_over_time(claude_code_session_count_total[$__range])))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "トークン消費レート(モデル別、トークン/秒)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "instant": false,
          "range": true
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "トークン消費の内訳(モデル別、選択期間の合計)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "コストの内訳(モデル別、選択期間の合計、USD)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "ツール呼び出し頻度(選択期間の合計)",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" [$__range]))",
          "legendFormat": "{{tool_name}}",
          "queryType": "instant",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "ツール呼び出し失敗率(選択期間)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | success=\"false\" [$__range])) / sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" [$__range]))",
          "queryType": "instant",
          "instant": true
        }
      ]
    }
  ]
}
