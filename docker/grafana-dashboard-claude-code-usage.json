{
  "uid": "claude-code-usage-summary",
  "title": "Claude Code 利用サマリー",
  "tags": ["claude-code", "daimon"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 20,
      "type": "row",
      "title": "トークン・コスト・セッション実績 (Prometheus)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "トークン消費(選択期間の合計)",
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(claude_code_token_usage_tokens_total[$__range]))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "コスト(選択期間の合計、USD)",
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "アクティブ時間(選択期間の合計)",
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(claude_code_active_time_seconds_total[$__range]))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "セッション数(選択期間内に開始)",
      "description": "increase() ではなく session_id の種類数で数える。claude_code_session_count_total ではなく token_usage_tokens_total ベースで数える(session_count_total は約10%程度過小カウントすることを確認済み。理由・実測値は docs/scenarios.md シナリオ5、.claude/skills/claude-observability/SKILL.md 参照)。",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(count by (session_id) (last_over_time(claude_code_token_usage_tokens_total[$__range])))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "トークン消費レート(モデル別、トークン/秒)",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "instant": false,
          "range": true
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "トークン消費の内訳(モデル別、選択期間の合計)",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "コストの内訳(モデル別、選択期間の合計、USD)",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 21,
      "type": "row",
      "title": "ツール利用状況 (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "ツール呼び出し頻度(選択期間の合計)",
      "gridPos": { "h": 4, "w": 16, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" [$__range]))",
          "legendFormat": "{{tool_name}}",
          "queryType": "instant",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "ツール呼び出し失敗率(選択期間)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | success=\"false\" [$__range])) / sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" [$__range]))",
          "queryType": "instant",
          "instant": true
        }
      ]
    },
    {
      "id": 22,
      "type": "row",
      "title": "トレース (Tempo、ベータ)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "table",
      "title": "ツール所要時間 p95(ツール別、直近3時間固定)",
      "description": "Tempo の TraceQL metrics クエリは3時間を超える時間範囲を受け付けないため、このパネルはダッシュボード上部の時間範囲ピッカーに関わらず常に直近3時間で集計する(パネル右上の時計アイコンが範囲上書きの印)。table タイプなのは、この形(ラベルの組み合わせごとに1値ずつ、別々のフレーム)のレスポンスに対して Tempo データソース自身が preferredVisualisationType: table を返すため(bargauge では正しく表示されないことを確認済み)。詳細・実測値は .claude/skills/claude-observability/SKILL.md の「Tool-call frequency and duration」節、docs/scenarios.md を参照。",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 19 },
      "timeFrom": "3h",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "merge", "options": {} }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "metricsQueryType": "instant",
          "query": "{ resource.service.name = \"claude-code\" && span.tool_name != nil } | quantile_over_time(span:duration, .95) by (span.tool_name)",
          "filters": []
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "直近のインタラクション(Tempo トレース一覧)",
      "description": "claude_code.interaction スパン(ターン単位)の一覧。トレース ID をクリックすると Tempo のトレース詳細(waterfall)を開ける。検索系クエリのため TraceQL metrics のような3時間上限はなく、上部の時間範囲ピッカーに従う。",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"claude-code\" && name = \"claude_code.interaction\" }",
          "filters": [],
          "limit": 15,
          "tableType": "traces"
        }
      ]
    }
  ]
}
